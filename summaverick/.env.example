# Copy to .env and fill in to enable the online (NIM) path.
# Leave everything blank to run in offline heuristic mode (default; fully demoable).

# NVIDIA NIM (OpenAI-compatible endpoint)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_REASONING_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
NIM_LIGHT_MODEL=nvidia/nemotron-mini-4b-instruct

# Storage (demo uses SQLite; set to switch to Postgres+pgvector)
SUMMAVERICK_DB=backend/memory/summaverick.db
# DATABASE_URL=postgresql+psycopg://summaverick:summaverick@localhost:5432/summaverick
